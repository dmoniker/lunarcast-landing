# Waitlist (optional — set one). Used for iOS beta + App Store launch emails only.

# ConvertKit: open your form → Embed → find the form action URL (POST to https://app.convertkit.com/forms/…/subscriptions)
# NEXT_PUBLIC_CONVERTKIT_FORM_ACTION=https://app.convertkit.com/forms/1234567890/subscriptions

# Google Forms: create form → Send → <> embed → copy the iframe src (must include ?embedded=true)
# NEXT_PUBLIC_WAITLIST_FORM_EMBED_URL=https://docs.google.com/forms/d/e/1FAIpQLS…/viewform?embedded=true
